# Local runtime config for the BTC 10-Strategy dashboard.
# Copy to .env and edit — .env is gitignored, so each checkout/branch keeps its
# own port and no port change is ever committed.
#
#   cp .env.example .env
#
# An inline override still wins over this file:  PORT=9000 ./run.sh

# Port the dashboard listens on. Give every parallel checkout a distinct value.
PORT=8100

# Bind address. 0.0.0.0 exposes it on the network; 127.0.0.1 is local-only.
HOST=0.0.0.0
